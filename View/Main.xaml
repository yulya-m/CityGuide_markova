<Page x:Class="CityGuide29.Markova.View.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CityGuide29.Markova.View"
      xmlns:elements="clr-namespace:CityGuide29.Markova.View.Items"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">
    <Page.Resources>
        <Style TargetType="Button" x:Key="AddButton">
            <Setter Property="Background" Value="#FF4A90D9"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Page.Resources>
    <Grid>
        <ListView ItemsSource="{Binding Cities}" Margin="0,0,0,45">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <elements:CityItem DataContext="{Binding}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button
            Style="{StaticResource AddButton}"
            Command="{Binding OnAddCity}"
            Content="Добавить"
            Height="25"
            Width="70"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            Margin="0,0,10,10"/>
    </Grid>
</Page>
